# Copiez ce fichier en .env et adaptez les valeurs
# Sur Railway, configurez ces variables dans les paramètres du projet

# Port du serveur (Railway le définit automatiquement)
PORT=3000

# Mot de passe pour accéder au tableau de bord web
DASHBOARD_PASSWORD=MotDePasseTresSecret123

# Token secret partagé avec l'app Android
# Doit être identique dans l'app Android et ici
DEVICE_TOKEN=mon-token-android-super-secret

# Clé secrète pour les tokens JWT (mettez une longue chaîne aléatoire)
SECRET_KEY=cle-jwt-longue-et-completement-aleatoire-changez-moi

